rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read for all files.
    match /{allPaths=**} {
      allow read;
    }

    // Allow writes to the 'images' folder only for authenticated users.
    match /images/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
